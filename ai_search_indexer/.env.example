# ═══════════════════════════════════════════════════════════════════════════════
# AI Search Indexer — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to azure_config.env and fill in your values.
# The deploy script loads this file automatically.

# ── Azure Subscription ───────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# ── AI Search Service ────────────────────────────────────────────────────────
AI_SEARCH_NAME=                  # e.g. my-search-service (just the name, not full URL)

# ── Storage Account (for blob data sources) ──────────────────────────────────
STORAGE_ACCOUNT_NAME=            # e.g. mystorage123

# ── AI Foundry / Azure OpenAI (for embeddings) ──────────────────────────────
AI_FOUNDRY_NAME=                 # e.g. my-ai-foundry (just the name, not full URL)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
