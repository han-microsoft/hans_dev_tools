# Fabric credentials (cross-tenant service principal)
FABRIC_TENANT_ID=your-tenant-id
FABRIC_CLIENT_ID=your-client-id
FABRIC_CLIENT_SECRET=your-client-secret

# Graph Model
FABRIC_WORKSPACE_ID=your-workspace-id
FABRIC_GRAPH_MODEL_ID=your-graph-model-id

# Eventhouse / KQL
EVENTHOUSE_QUERY_URI=https://your-cluster.kusto.fabric.microsoft.com
FABRIC_KQL_DB_NAME=your-database-name

# Optional tuning
# FABRIC_MAX_CONCURRENT=2
# FABRIC_API_URL=https://api.fabric.microsoft.com/v1
