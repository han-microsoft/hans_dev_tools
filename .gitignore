# ═══════════════════════════════════════════════════════════════════════════════
# Han's Toolkit — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# ── Python / Backend ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
*.egg

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
azure_config.env
!.env.example

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Lock files (keep package.json, ignore locks) ─────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
