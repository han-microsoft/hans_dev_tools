# ═══════════════════════════════════════════════════════════════════════════════
# Streaming Chat UI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The backend loads this file at startup via pydantic-settings.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" | "agent" | "echo" | "mock"
#   openai — Direct OpenAI-compatible API (Azure OpenAI or openai.com)
#   agent  — Azure AI Foundry Agent (requires AZURE_AI_PROJECT_ENDPOINT)
#   echo   — Dev mode: parrots user message back word-by-word
#   mock   — Dev mode: canned rich response with tool calls
LLM_PROVIDER=echo

# ── OpenAI / Azure OpenAI ────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=                  # e.g. https://<resource>.openai.azure.com/openai/deployments/<deployment>
LLM_MODEL=gpt-4.1

# ── Azure AI Foundry Agent ───────────────────────────────────────────────────
# Required when LLM_PROVIDER=agent
AZURE_AI_PROJECT_ENDPOINT=     # e.g. https://<hub>.services.ai.azure.com/api/projects/<project>
AZURE_AI_AGENT_ID=             # Agent ID from Foundry portal

# ── Context Window ───────────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=120000
MAX_RESPONSE_TOKENS=4096
SYSTEM_PROMPT=You are a helpful assistant.

# ── Server ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DEBUG=false
